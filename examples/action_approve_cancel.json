{
  "text": "## Approval request",
  "blocks": [
    {
      "type": "text",
      "text": "Review the request below and choose an action."
    },
    {
      "type": "separator"
    },
    {
      "type": "text",
      "text": "- Request ID: REQ-001\n- Owner: taco\n- Scope: retry last deployment"
    },
    {
      "type": "actions",
      "buttons": [
        {
          "label": "Approve",
          "style": "success",
          "action": "workflow.approve",
          "args": {
            "decision": "approve"
          },
          "allowed_users": [
            "user:123456789012345678"
          ]
        },
        {
          "label": "Cancel",
          "style": "danger",
          "action": "discord.reply_text",
          "args": {
            "text": "Cancelled."
          },
          "interaction": {
            "response": {
              "mode": "errors-only",
              "show_success": false,
              "local_success_text": "Cancelled."
            }
          }
        }
      ]
    }
  ],
  "action_data": {
    "kind": "dispatch",
    "agent_hint": "discord-test",
    "session_hint": "session:approval-demo",
    "thread_hint": "req-001",
    "interaction": {
      "response": {
        "transport_success_text": "Approval request forwarded to OpenClaw.",
        "delayed_text": "Approval click accepted, but downstream delivery was delayed.",
        "error_text": "Approval handling failed. Check bridge logs."
      }
    },
    "args": {
      "request_id": "REQ-001"
    }
  },
  "reusable": false
}
