{
  "text": "## Restricted action",
  "blocks": [
    {
      "type": "text",
      "text": "Only the configured Discord user may approve this operation."
    },
    {
      "type": "actions",
      "buttons": [
        {
          "label": "Approve",
          "style": "success",
          "action": "workflow.approve",
          "allowed_users": [
            "user:123456789012345678"
          ]
        },
        {
          "label": "Cancel",
          "style": "danger",
          "action": "discord.reply_text",
          "args": {
            "text": "Cancelled."
          },
          "interaction": {
            "response": {
              "mode": "errors-only",
              "show_success": false
            }
          }
        }
      ]
    }
  ],
  "action_data": {
    "kind": "dispatch",
    "agent_hint": "discord-test",
    "session_hint": "session:restricted-demo",
    "interaction": {
      "response": {
        "transport_success_text": "Restricted action forwarded to OpenClaw.",
        "error_text": "Restricted action failed. Verify permissions and routing."
      }
    },
    "args": {
      "request_id": "demo-001"
    }
  },
  "reusable": false
}
