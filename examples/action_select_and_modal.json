{
  "text": "## Interactive bridge demo",
  "blocks": [
    {
      "type": "text",
      "text": "This example shows a reusable select plus a modal trigger."
    },
    {
      "type": "actions",
      "select": {
        "type": "string",
        "action": "workflow.set_priority",
        "placeholder": "Set priority",
        "options": [
          { "label": "Low", "value": "low" },
          { "label": "Normal", "value": "normal" },
          { "label": "High", "value": "high" }
        ],
        "max_values": 1,
        "interaction": {
          "response": {
            "transport_success_text": "Priority change forwarded to OpenClaw.",
            "delayed_text": "Priority selection accepted, but delivery was delayed."
          }
        }
      }
    }
  ],
  "modal": {
    "title": "Add details",
    "triggerLabel": "Open form",
    "action": "workflow.submit_details",
    "trigger_reusable": true,
    "submit_single_use": true,
    "fields": [
      {
        "type": "text",
        "label": "Requester",
        "custom_id": "requester",
        "style": 1,
        "required": false
      },
      {
        "type": "text",
        "label": "Details",
        "custom_id": "details",
        "style": 2,
        "required": false
      }
    ]
  },
  "action_data": {
    "kind": "dispatch",
    "agent_hint": "discord-test",
    "session_hint": "session:select-modal-demo",
    "thread_hint": "priority-form",
    "interaction": {
      "response": {
        "transport_success_text": "Interactive action forwarded to OpenClaw.",
        "delayed_text": "The interaction was accepted, but downstream delivery was delayed.",
        "error_text": "The interactive action failed. Inspect bridge logs."
      }
    },
    "args": {
      "request_id": "demo-select-modal-001"
    }
  },
  "reusable": true
}
